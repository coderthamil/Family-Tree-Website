# === Database ===
DATABASE_URL="postgresql+asyncpg://postgres:12345678@localhost:5432/family_tree"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345678
POSTGRES_DB=family_tree

# === Auth ===
JWT_SECRET_KEY="change-me-to-a-long-random-string"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# === Storage ===
# Options: local | s3
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# S3-compatible (fill if STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=family-tree-uploads
S3_REGION=us-east-1

# === App ===
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
APP_ENV=development
